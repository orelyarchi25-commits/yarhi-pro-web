# העתק ל-.env.local והדבק את הערכים מ-Firebase Console → Project settings → Your apps → Config
# אל תעלה .env.local ל-Git

# מצב חירום לפיתוח מקומי: 1 = ביטול Firebase והרצה במצב מקומי בלבד
# NEXT_PUBLIC_DISABLE_FIREBASE=1

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# מספר וואטסאפ לקבלת הזמנות קיטים (בפורמט בינלאומי, ספרות בלבד; לדוגמה: 9725XXXXXXXX)
NEXT_PUBLIC_WHATSAPP_PHONE=

# --- התראה במייל על רישום קבלן חדש (שרת בלבד) ---
# אפשרות א׳ (מומלץ): העתק את קובץ ה-JSON לשורש הפרויקט כ־firebase-service-account.json (ב־gitignore)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# --- פיתוח (next dev): התחברות אוטומטית עם Custom Token כמשתמש קבוע ---
# דורש FIREBASE_SERVICE_ACCOUNT_* למעלה. ברירת מחדל: yarchialuminum@gmail.com
# DEV_IMPERSONATE_EMAIL=yarchialuminum@gmail.com
# אפשרות ב׳: JSON מלא בשורה אחת (minify)
# FIREBASE_SERVICE_ACCOUNT_JSON=
# Resend: https://resend.com — API key + אימות דומיין (או onboarding@resend.dev לבדיקות)
RESEND_API_KEY=
# לאן לשלוח את ההתראה (מותר כמה כתובות מופרדות בפסיק)
ADMIN_NOTIFY_EMAIL=
# אופציונלי: כתובת שולח (חייב להיות מדומיין מאומת ב-Resend)
# EMAIL_FROM=Yarhi Pro <onboarding@resend.dev>
# קישור מלא במייל ההתראה לדף /admin/approve (מומלץ בפרודקשן)
# NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# דף אישור קבלן + תוקף — סיסמה סודית (הזן בטופס, לא בקוד)
ADMIN_APPROVE_SECRET=
