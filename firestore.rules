rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // users/{uid}: לא ניתן להגדיר accountApproved: true מהלקוח — רק מנהל ב-Console / Admin SDK
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null && request.auth.uid == userId
        && request.resource.data.accountApproved == false;

      allow update: if request.auth != null && request.auth.uid == userId
        && (request.resource.data.accountApproved != true || resource.data.accountApproved == true);
    }
  }
}
